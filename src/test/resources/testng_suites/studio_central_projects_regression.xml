<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite verbose="1" name="Central Projects" annotations="JDK" parallel="tests" thread-count="1">

    <listeners>
        <listener class-name="configuration.listeners.AnnotationTransformer"/>
        <listener class-name="configuration.listeners.StudioCentralReportPortalListener"/>
    </listeners>

    <test name="Group 1: rating + claim">
        <classes><class name="tests.api.webstudio.client.TestStudioCentralGroupRatingClaim"/></classes>
    </test>

    <test name="Group 2: policy bundle">
        <classes><class name="tests.api.webstudio.client.TestStudioCentralGroupPolicyBundle"/></classes>
    </test>

</suite>
