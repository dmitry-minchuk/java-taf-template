<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite verbose="1" name="WebStudio Git Tests" annotations="JDK" parallel="tests" thread-count="1">
    <listeners>
        <listener class-name="configuration.listeners.AnnotationTransformer"/>
        <listener class-name="com.epam.reportportal.testng.ReportPortalTestNGListener"/>
    </listeners>

    <test name="TestGitBranchSwitching"><classes><class name="tests.ui.webstudio.git.TestGitBranchSwitching"/></classes></test>
    <test name="TestGitSortingExcelFilesInComparePopUp"><classes><class name="tests.ui.webstudio.git.TestGitSortingExcelFilesInComparePopUp"/></classes></test>
    <test name="TestGitStatusCopyClosedProject"><classes><class name="tests.ui.webstudio.git.TestGitStatusCopyClosedProject"/></classes></test>
    <test name="TestGitSwitchBranchProjectWithoutChanges"><classes><class name="tests.ui.webstudio.git.TestGitSwitchBranchProjectWithoutChanges"/></classes></test>
    <test name="TestGitNewBranchCreatedFromMaster"><classes><class name="tests.ui.webstudio.git.TestGitNewBranchCreatedFromMaster"/></classes></test>
    <test name="TestGitCopyProjectIntoExistingBranchViaRepositoryTab"><classes><class name="tests.ui.webstudio.git.TestGitCopyProjectIntoExistingBranchViaRepositoryTab"/></classes></test>
    <test name="TestGitCopyProjectIntoExistingBranchViaEditorTab"><classes><class name="tests.ui.webstudio.git.TestGitCopyProjectIntoExistingBranchViaEditorTab"/></classes></test>
    <test name="TestGitSwitchToDeletedBranch"><classes><class name="tests.ui.webstudio.git.TestGitSwitchToDeletedBranch"/></classes></test>
    <test name="TestGitSwitchDeletedBranchPreset"><classes><class name="tests.ui.webstudio.git.TestGitSwitchDeletedBranchPreset"/></classes></test>
    <test name="TestMergeBranchesNoConflicts"><classes><class name="tests.ui.webstudio.git.TestMergeBranchesNoConflicts"/></classes></test>
    <test name="TestMergeBranchesWithConflicts"><classes><class name="tests.ui.webstudio.git.TestMergeBranchesWithConflicts"/></classes></test>
    <test name="TestProtectedBranchMergeProtection"><classes><class name="tests.ui.webstudio.git.TestProtectedBranchMergeProtection"/></classes></test>

</suite>
