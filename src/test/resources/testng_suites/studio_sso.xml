<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- PLAYWRIGHT_DOCKER suite: SSO / external-IdP UI tests. The browser runs inside the
     Docker network so it can reach Keycloak by the same alias as Studio and the token issuer.
     Run with: mvn test -Dsurefire.suiteXmlFiles=...studio_sso.xml -Dexecution.mode=PLAYWRIGHT_DOCKER -Djava.net.preferIPv4Stack=true -->
<suite verbose="1" name="WebStudio SSO Tests" annotations="JDK" parallel="tests" thread-count="1">

    <listeners>
        <listener class-name="configuration.listeners.AnnotationTransformer"/>
        <listener class-name="com.epam.reportportal.testng.ReportPortalTestNGListener"/>
    </listeners>

    <test name="TestProtectedBranchBypassGroupMembershipUi"><classes><class name="tests.ui.webstudio.sso.TestProtectedBranchBypassGroupMembershipUi"/></classes></test>
    <test name="TestUsersViewRolesOauth2Ui"><classes><class name="tests.ui.webstudio.sso.TestUsersViewRolesOauth2Ui"/></classes></test>
    <test name="TestUsersViewRolesSamlUi"><classes><class name="tests.ui.webstudio.sso.TestUsersViewRolesSamlUi"/></classes></test>
    <test name="TestSamlLogoutUi"><classes><class name="tests.ui.webstudio.sso.TestSamlLogoutUi"/></classes></test>
    <test name="TestOidcLogoutUi"><classes><class name="tests.ui.webstudio.sso.TestOidcLogoutUi"/></classes></test>
    <test name="TestAdAuthUi"><classes><class name="tests.ui.webstudio.ad.TestAdAuthUi"/></classes></test>
    <test name="TestPersonalAccessTokenAdUi"><classes><class name="tests.ui.webstudio.ad.TestPersonalAccessTokenAdUi"/></classes></test>

</suite>
