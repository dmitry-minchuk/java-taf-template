    <test name="TestMethodTable"><classes><class name="tests.ui.webstudio.rules_editor.TestMethodTable"/></classes></test>
    <test name="TestViewStackTraceFunctionality"><classes><class name="tests.ui.webstudio.rules_editor.TestViewStackTraceFunctionality"/></classes></test>
    <test name="TestModuleCategoryInheritedProperties"><classes><class name="tests.ui.webstudio.rules_editor.TestModuleCategoryInheritedProperties"/></classes></test>
    <test name="TestCompareSelectedVersions"><classes><class name="tests.ui.webstudio.rules_editor.TestCompareSelectedVersions"/></classes></test>
    <test name="TestDefaultProperties"><classes><class name="tests.ui.webstudio.rules_editor.TestDefaultProperties"/></classes></test>
    <test name="TestRestrictionsErrorMessagesForProperties"><classes><class name="tests.ui.webstudio.rules_editor.TestRestrictionsErrorMessagesForProperties"/></classes></test>
    <test name="TestReturnCellsMarksWithStar"><classes><class name="tests.ui.webstudio.rules_editor.TestReturnCellsMarksWithStar"/></classes></test>

