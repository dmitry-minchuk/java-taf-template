<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="info">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%t%X{threadId}] [%p] %m%n"/>
        </Console>
        <ReportPortalLog4j2Appender name="ReportPortalAppender">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%t%X{threadId}] [%p] %m%n%throwable{full}"/>
        </ReportPortalLog4j2Appender>
    </Appenders>
    <Loggers>
        <Logger name="org.testcontainers" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <Logger name="com.github.dockerjava" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <!-- Set -Dlog.api.level=debug to enable full request/response logging for API calls -->
        <Logger name="domain.api" level="${sys:log.api.level:-info}" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ReportPortalAppender"/>
        </Logger>
        <Logger name="configuration.listeners.RestAssuredFilter" level="${sys:log.api.level:-info}" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ReportPortalAppender"/>
        </Logger>
        <Logger name="helpers.utils.WaitUtil" level="${sys:log.api.level:-info}" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ReportPortalAppender"/>
        </Logger>
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ReportPortalAppender"/>
        </Root>
    </Loggers>
</Configuration>
